DB_URL=postgresql+psycopg2://databaser_user:user_pw@host/db_name

DEBUG=true

SECRET_KEY=openssl rand -hex 32
ALGORITHM=HS_256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI agent (required)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mint-ai
GEMINI_API_KEY=
TAVILY_API_KEY=

# Price-data providers (optional; assets without a key fall back to manual prices).
# CoinMarketCap free "Basic" plan covers crypto + gold/silver (via PAXG/KAG).
# FX uses keyless open.er-api.com, so FX_API_KEY is not required.
COINMARKETCAP_API_KEY=
COINGECKO_API_KEY=
METAL_API_KEY=
FX_API_KEY=

# How long a cached price/FX snapshot stays fresh, in seconds (default 3600).
PRICE_TTL_SECONDS=3600
